# ── WasteHotspot Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# Supabase — get from https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# PostgreSQL connection string (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# OpenRouteService — free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your-openrouteservice-key

# JSON Web Token secret — change before any shared/production deploy
JWT_SECRET=change_me_to_a_long_random_string
# Set true to enforce JWT on dispatcher/driver/admin routes (NFR-08).
AUTH_REQUIRED=false

# FastAPI server port
PORT=8000

# App base URL (used for QR code generation)
APP_URL=http://localhost:5173

# H3 spatial lookup. TRD v1.1 uses resolution 9, ring-2 primary,
# ring-3 fallback before manual escalation.
H3_RESOLUTION=9
TRUCK_NEARBY_RING=2
TRUCK_FALLBACK_RING=3

# Routing engine thresholds (override defaults without code change)
CAPACITY_WARN_PCT=70
CAPACITY_FULL_PCT=90
DETOUR_CHEAP_MIN=15
DETOUR_MAX_MIN=30
CLUSTER_RADIUS_M=50
CLUSTER_WINDOW_MIN=30
SCORE_RERUN_THRESHOLD=70
TRUCK_POLL_INTERVAL_MS=60000
DASHBOARD_POLL_INTERVAL_MS=10000
