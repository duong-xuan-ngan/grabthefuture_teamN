# WasteHotspot frontend environment

# Backend base URL. Leave blank or set VITE_USE_MOCK=true to run with the
# bundled mock data layer. FastAPI backend runs on :8000.
VITE_API_URL=http://localhost:8000

# Set to "true" to force the mock data layer regardless of VITE_API_URL.
VITE_USE_MOCK=false

# Polling interval for the dispatcher dashboard (ms). NFR-02 ≤ 5s for
# routing; default 10s for dashboard polls.
VITE_POLL_INTERVAL=10000

# Driver app is pinned to one truck for the demo. Mock mode uses 'tr-B';
# the real backend seeds integer ids (1 = Truck Alpha, 2 = Truck Beta).
VITE_DRIVER_TRUCK_ID=1
